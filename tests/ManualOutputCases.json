      "id": "SEL-039",
      "title": "HAVING",
      "sql_lines": [
        "select",
        "    tb1.status",
        "    , count(tb1.user_id) as user_count ",
        "from",
        "    users as tb1 ",
        "group by",
        "    tb1.status ",
        "having",
        "    count(tb1.user_id) >= 10"
      ],
      "definitions": [
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "status", "field_name_ja": "状態" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "user_id", "field_name_ja": "ユーザーID" }
      ]
    },
    {
      "id": "SEL-040",
      "title": "CASE WHEN ELSE",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , case ",
        "        when tb1.status = 'ACTIVE' ",
        "            then '有効' ",
        "        else '無効' ",
        "        end as status_name ",
        "from",
        "    users as tb1"
      ],
      "definitions": [
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "user_id", "field_name_ja": "ユーザーID" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "status", "field_name_ja": "状態" }
      ]
    },
    {
      "id": "SEL-041",
      "title": "複雑な括弧条件",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , tb1.name ",
        "from",
        "    users as tb1 ",
        "where",
        "    ( ",
        "        tb1.status = @status ",
        "        and (tb1.name like @name + '%' or tb1.email = @email)",
        "    ) ",
        "    and not ( ",
        "        tb1.deleted_at is not null ",
        "        or tb1.user_id in (@excluded_user_id1, @excluded_user_id2)",
        "    )"
      ],
      "definitions": [
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "user_id", "field_name_ja": "ユーザーID" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "name", "field_name_ja": "氏名" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "status", "field_name_ja": "状態" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "email", "field_name_ja": "メール" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "deleted_at", "field_name_ja": "削除日時" }
      ]
    },
    {
      "id": "SEL-042",
      "title": "サブクエリ",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , tb1.name ",
        "from",
        "    users as tb1 ",
        "where",
        "    tb1.user_id in ( ",
        "        select",
        "            tb2.user_id ",
        "        from",
        "            orders as tb2 ",
        "        where",
        "            tb2.status = @status",
        "    )"
      ],
      "definitions": [
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "user_id", "field_name_ja": "ユーザーID" },
        { "table_id": "tb1", "table_name_ja": "ユーザー", "field_id": "name", "field_name_ja": "氏名" },
        { "table_id": "tb2", "table_name_ja": "注文", "field_id": "user_id", "field_name_ja": "注文ユーザーID" },
        { "table_id": "tb2", "table_name_ja": "注文", "field_id": "status", "field_name_ja": "状態" }
