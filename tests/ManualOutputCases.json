    },
    {
      "id": "SEL-043",
      "title": "WITH",
      "sql_lines": [
        "with target_users as ( ",
        "    select",
        "        tb1.user_id",
        "        , tb1.name ",
        "    from",
        "        users as tb1 ",
        "    where",
        "        tb1.status = @status",
        ") ",
        "select",
        "    target_users.user_id",
        "    , target_users.name ",
        "from",
        "    target_users"
