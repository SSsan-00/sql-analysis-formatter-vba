      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-023",
      "sql_lines": ["SELECT", "    tb1.注文ID", "    , DATEADD(DAY, 7, tb1.作成日時) AS due_date", "    , DATEADD(MONTH, 1, tb1.作成日時) AS next_month_date", "FROM", "    orders AS tb1"],
