      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-020",
      "sql_lines": ["SELECT", "    tb1.注文ID", "    , ROUND(tb1.金額, 0) AS amount_round0", "    , ROUND(tb1.金額, 2, 1) AS amount_truncate2", "FROM", "    orders AS tb1"],
      "tables": { "tb1": "注文" }
    },
    {
      "id": "SEL-021",
      "sql_lines": ["SELECT", "    SUM(tb1.金額) AS total_amount", "FROM", "    orders AS tb1"],
