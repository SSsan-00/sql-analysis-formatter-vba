      "tables": { "tb1": "注文" }
    },
    {
      "id": "SEL-018",
      "sql_lines": ["SELECT", "    tb1.ユーザーID", "    , ISNULL(tb1.メール, 'unknown') AS email_text", "    , ISNULL(tb1.状態, 'UNKNOWN') AS status_text", "FROM", "    users AS tb1"],
      "tables": { "tb1": "ユーザー" }
    },
    {
